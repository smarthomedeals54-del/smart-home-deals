<!DOCTYPE html>
<html>
<head>
  <title>Smart Home Deals</title>
  <style>
    body { font-family: Arial; background:#f1f3f6; }
    h1 { text-align:center; color:#2874f0; }
    .grid { display:grid; grid-template-columns:repeat(2,1fr); gap:10px; padding:10px; }
    .card { background:white; padding:10px; border-radius:10px; text-align:center; }
    img { width:100%; height:120px; object-fit:cover; }
    button { background:#25D366; color:white; border:none; padding:10px; border-radius:5px; }
  </style>
</head>
<body>

<h1>Smart Home Deals</h1>

<div class="grid">

  <div class="card">
    <img src="https://via.placeholder.com/150">
    <h3>Washing Machine Cover</h3>
    <p>₹499</p>
    <a href="https://wa.me/918309386576?text=I want to order Washing Machine Cover">
      <button>Order on WhatsApp</button>
    </a>
  </div>

  <div class="card">
    <img src="https://via.placeholder.com/150">
    <h3>Fridge Stand</h3>
    <p>₹799</p>
    <a href="https://wa.me/918309386576?text=I want to order Fridge Stand">
      <button>Order on WhatsApp</button>
    </a>
  </div>

</div>

</body>
</html>
